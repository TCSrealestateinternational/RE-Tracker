rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is the agent who owns this data
    function isAgent() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Check if user is a client linked to this agent's data
    function isLinkedClient(agentId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "client"
        && get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.agentId == agentId;
    }

    // ── User Profiles ──
    match /userProfiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ── Client Invites ──
    match /clientInvites/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || request.auth.token.email == resource.data.clientEmail);
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuthenticated();
    }

    // ── Agent-owned collections (agent can read/write, linked client can read) ──
    match /timeEntries/{docId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /clients/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /deals/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /checklists/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
            || isLinkedClient(resource.data.userId));
      allow write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /dailyCheckIns/{docId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /incomeGoals/{docId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    match /referrals/{docId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Portal Collections ──
    match /decisions/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.agentId;
    }

    match /costBreakdowns/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.agentId;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.agentId;
    }

    match /marketData/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || isLinkedClient(resource.data.agentId));
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.agentId;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.agentId;
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.agentId;
    }

    // ── Messaging ──
    match /conversations/{docId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || request.auth.uid == resource.data.clientUserId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.agentId
            || request.auth.uid == resource.data.clientUserId);
    }

    match /messages/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.senderId;
    }
  }
}
